{
  "name": "decode-claude-restored",
  "private": true,
  "type": "module",
  "description": "Readable restored modules from the Claude desktop app bundle.",
  "scripts": {
    "refresh-ref": "make refresh-ref",
    "inspect": "make inspect",
    "deobf-plan": "make deobf-plan",
    "runtime-map": "make runtime-map",
    "quality": "make quality",
    "typecheck": "tsc --noEmit",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:main": "vite build --config vite.main.config.ts",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build": "bun run build:preload && bun run build:main && bun run build:renderer",
    "start": "bun run build && bun run electron dist/main/index.js",
    "dev": "node scripts/dev.mjs",
    "pack-ref": "make pack-ref"
  },
  "dependencies": {
    "3dmol": "^2.5.5",
    "@floating-ui/react-dom": "^2.1.2",
    "@lottiefiles/dotlottie-react": "^0.19.8",
