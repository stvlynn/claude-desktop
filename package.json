    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-popover": "^1.1.19",
    "@sentry/electron": "^7.15.0",
    "@shikijs/langs": "^4.3.1",
    "@shikijs/themes": "^4.3.1",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3-array": "^3.2.4",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "d3-time": "^3.1.0",
    "dayjs": "^1.11.21",
    "file-type": "22.0.1",
    "framer-motion": "^12.42.2",
    "fuse.js": "^7.4.2",
    "jotai": "^2.20.1",
    "katex": "^0.16.21",
    "mime-types": "^3.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "7.1.11",
    "react-router": "^6.29.0",
    "rrule": "^2.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/asar": "^3.4.1",
    "@types/d3-array": "^3.2.2",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-time": "^3.0.4",
    "@types/mime-types": "^3.0.1",
    "@types/node": "~22.15.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "42.5.1",
    "prettier": "^3.7.4",
    "typescript": "~6.0.3",
    "vite": "^6.4.2"
  }
